 <Window x:Class="laborator6_ta.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:laborator6_ta"
        mc:Ignorable="d"
        Title="Music Store" Height="450" Width="800"
        Background="Beige">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="BlanchedAlmond" CornerRadius="10" Padding="10">
            <StackPanel>
                <TextBlock Text="Descriere produs"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="SaddleBrown"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Set de tobe acustice profesionale, ideal pentru concerte si studio. Include toba mare, snare, tom-uri si cinele de calitate superioara."
                           TextWrapping="Wrap"
                           FontFamily="Rockwell"
                           Foreground="SaddleBrown"/>

                <TextBlock Text="Specificatii:"
                           Margin="0,15,0,5"
                           FontWeight="Bold"
                           Foreground="SaddleBrown"/>

                <TextBlock Text="- Material: Lemn premium&#10;- Include cinele&#10;- Sunet profesional"
                           TextWrapping="Wrap"
                           Foreground="SaddleBrown"/>

                <TextBlock Text="Pret: 20.000 RON"
                           Margin="0,15,0,5"
                           FontWeight="Bold"
                           FontFamily="Rockwell"
                           Foreground="SaddleBrown"/>
                <Button Content="Cumpara"
                    Margin="0,15,0,5"
                    Width="120"
                    Height="50"
                    HorizontalAlignment="Center"
                    Background="IndianRed"
                    Foreground="White"
                    FontWeight="Bold"
                    FontFamily="Rockwell"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Column="1" Margin="10,0,0,0">

            <Label Content="MUSIC STORE"
                   Foreground="OldLace"
                   Background="BurlyWood"
                   FontFamily="Rockwell"
                   FontSize="36"
                   HorizontalContentAlignment="Center"/>

            <Label Content="Tobe si Percutie"
                   Foreground="PaleVioletRed"
                   Background="BlanchedAlmond"
                   FontFamily="Rockwell"
                   FontSize="18"
                   HorizontalContentAlignment="Center"/>

            <Border Background="BlanchedAlmond" CornerRadius="10" Margin="0,10">
                <StackPanel Margin="10">
                    <Label Content="Categorii"
                           FontWeight="Bold"
                           Foreground="SaddleBrown"
                           FontFamily="Rockwell Extra Bold"/>

                    <Label Content="Tobe acustice" Foreground="SaddleBrown"/>
                    <Label Content="Cinele" Foreground="SaddleBrown"/>
                </StackPanel>
            </Border>
            <Image Source="D:\COD\C#\laborator6_ta\thumb_m_gallery_c10ab73c.webp"
                   Width="350"
                   Height="220"
                   Stretch="Uniform"
                   />
            <Label Content="20.000 RON"
                   HorizontalAlignment="Center"
                   FontSize="22"
                   Foreground="IndianRed"
                   FontFamily="Rockwell Extra Bold"
                   Margin="0,10"/>
        </StackPanel>

    </Grid>
</Window>
